FROM node:20-alpine AS build
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* frontend/yarn.lock* ./
RUN npm install
COPY frontend /app
RUN npm run build || true

FROM node:20-alpine
WORKDIR /app
COPY --from=build /app /app
EXPOSE 9000
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "9000"]
